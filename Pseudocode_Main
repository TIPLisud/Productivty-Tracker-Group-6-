FUNCTION ProductivityManagementSystem():
    WHILE True:
        DISPLAY "Productivity Management System"
        DISPLAY "1. Create Account"
        DISPLAY "2. Login"
        DISPLAY "3. Exit"
        
        INPUT choice
        
        IF choice == 1:
            # CREATE ACCOUNT BRANCH
            INPUT new_username
            INPUT new_password
            SAVE new_username AND new_password TO Database
            RESTART Loop (Go to PMS)
            
        ELSE IF choice == 2:
            # LOGIN BRANCH
            DISPLAY "Enter your username:"
            DISPLAY "Enter your password:"
            INPUT input_username
            INPUT input_password
            
            # VALIDATION
            IF input_username == stored_username AND input_password == stored_password:
                ACCEPT username
                ACCEPT password
                GO TO Main Menu (MM)
            ELSE:
                DISPLAY "Invalid username or password."
                RESTART Loop (Go to PMS)
                
        ELSE IF choice == 3:
            # EXIT 
            BREAK (End Program)
            
        ELSE:
            # NO PATH
            RESTART Loop (Go to PMS)
