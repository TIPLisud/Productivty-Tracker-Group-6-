FUNCTION MainMenu(username):
    WHILE True:
        DISPLAY "Main Menu: (User: " + username + ")"
        DISPLAY "1. View Project"
        DISPLAY "2. Create Project"
        DISPLAY "3. Logout"
        
        INPUT choice
        
        IF choice == 1:
            # VIEW PROJECT 
            CALL SHOW Projects
            RESTART Loop (Go back to MM)
            
        ELSE IF choice == 2:
            # CREATE PROJECT SUB-MENU
            DISPLAY "1. Solo Project"
            DISPLAY "2. Group Project"
            INPUT sub_choice
            
            IF sub_choice == 1:
                GO TO Solo Project Menu (SPM)
            ELSE IF sub_choice == 2:
                GO TO Group Project Menu (GPM)
            ELSE:
                RESTART Loop (Go back to MM)
                
        ELSE IF choice == 3:
            # LOGOUT 
            GO TO Productivity Management System (PMS)
            
        ELSE:
            # NO PATH / INVALID
            RESTART Loop (Go back to MM)
